#!/bin/bash
set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "Usage: new-claude-session <name>"
  echo ""
  echo "Launches Claude with --worktree, which creates or resumes a worktree"
  echo "at .claude/worktrees/<name>/. Task list persists across sessions."
  echo ""
  echo "  name    Worktree name (also used as task list ID)"
  echo ""
  echo "Worktree management:"
  echo "  git worktree list              List active worktrees"
  echo "  git worktree remove <path>     Remove a worktree"
  exit 1
fi

NAME="$1"
CLAUDE_CMD="${CLAUDE_CMD:-claude}"
CLAUDE_CODE_TASK_LIST_ID="$NAME" exec $CLAUDE_CMD --worktree "$NAME"
